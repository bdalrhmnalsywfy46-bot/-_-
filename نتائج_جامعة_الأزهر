        async function checkResult() {
            const seatInput = document.getElementById("seatInput").value;
            const idInput = document.getElementById("idInput").value;
            const errorMsg = document.getElementById("errorMsg");
            const searchBox = document.getElementById("searchBox");
            const resultBox = document.getElementById("resultBox");

            try {
                // إرسال الطلب إلى السيرفر (استبدل localhost برابط السيرفر الفعلي عند الرفع)
                const response = await fetch('http://localhost:3000/api/check-result', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ seatInput, idInput })
                });

                const result = await response.json();

                if (result.success) {
                    errorMsg.style.display = "none";
                    searchBox.style.display = "none";
                    resultBox.style.display = "block";

                    // تعبئة بيانات الطالب
                    document.getElementById("studentName").innerText = result.data.name;
                    document.getElementById("studentTrack").innerText = result.data.track;
                    document.getElementById("studentStatus").innerText = result.data.status;
                    document.getElementById("studentGpa").innerText = result.data.gpa;

