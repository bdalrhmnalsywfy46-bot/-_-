const cors = require('cors');
const app = express();

app.use(cors());
app.use(express.json());

// قاعدة بيانات تجريبية (يتم استبدالها لاحقاً بقاعدة بيانات حقيقية مثل MongoDB أو MySQL)
const studentsDatabase = [
